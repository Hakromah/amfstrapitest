{
  "kind": "collectionType",
  "collectionName": "school_classes",
  "info": {
    "singularName": "school-class",
    "pluralName": "school-classes",
    "displayName": "School Class"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "grade": {
      "type": "string"
    },
    "teachers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "teachingClasses"
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "enrolledClasses"
    }
  }
}
