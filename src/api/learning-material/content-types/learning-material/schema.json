{
  "kind": "collectionType",
  "collectionName": "learning_materials",
  "info": {
    "singularName": "learning-material",
    "pluralName": "learning-materials",
    "displayName": "Learning Material"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "fileUrl": {
      "type": "string"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files", "images", "videos", "audios"]
    },
    "classe": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::school-class.school-class"
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject"
    },
    "uploadedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
