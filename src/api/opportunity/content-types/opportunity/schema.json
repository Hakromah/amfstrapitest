{
  "kind": "collectionType",
  "collectionName": "opportunities",
  "info": {
    "singularName": "opportunity",
    "pluralName": "opportunities",
    "displayName": "Opportunity"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
