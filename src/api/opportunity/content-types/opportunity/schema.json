      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "deadline": {
      "type": "string"
    },
    "date_number": {
      "type": "string"
    },
    "index": {
      "type": "string"
    },
    "details_intro": {
      "type": "text"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "published_date": {
      "type": "date"
    },
    "how_to_apply": {
      "type": "text"
    },
    "requirements": {
      "type": "component",
      "component": "shared.benefit",
      "repeatable": true
    },
    "benefits": {
      "type": "component",
      "component": "shared.benefit",
      "repeatable": true
    },
    "header": {
      "type": "text"
    },
    "subheader": {
      "type": "text"
    },
    "breadcrumb_item": {
      "type": "component",
      "component": "shared.readcrumb",
      "repeatable": true
    }
  }
