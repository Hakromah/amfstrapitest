{
  "kind": "collectionType",
  "collectionName": "timetable_entries",
  "info": {
    "singularName": "timetable-entry",
    "pluralName": "timetable-entries",
    "displayName": "Timetable Entry"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "dayOfWeek": {
      "type": "enumeration",
      "enum": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"],
      "required": true
    },
    "startTime": {
      "type": "time",
      "required": true
    },
    "endTime": {
      "type": "time",
      "required": true
    },
    "classe": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::school-class.school-class"
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject"
    }
  }
}
